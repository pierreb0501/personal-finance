# Plaid (https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox # sandbox | development | production

# Turso (https://turso.tech) — libsql-compatible SQLite
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Set this in production (must be HTTPS). Used for Plaid's OAuth redirect_uri.
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Auth — required. Generate SESSION_SECRET with: openssl rand -base64 32
# APP_PASSWORD gates the entire app behind a single shared password (see
# lib/session.ts) — change it to something strong before deploying anywhere
# reachable by others.
SESSION_SECRET=
APP_PASSWORD=
